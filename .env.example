# =============================================================================
# Pudgy Huddle Health .env
# Copy to .env and fill in every *required* value before `docker compose up`.
# =============================================================================

# --- Indexer RPC (REQUIRED) --------------------------------------------------
# Ethereum mainnet JSON-RPC URL for the Ponder indexer. Infura, Alchemy, or
# any mainnet-archive-capable endpoint. Only the indexer container reads
# this. The web container intentionally has no reference to it.
PONDER_RPC_URL_1=https://mainnet.infura.io/v3/your_infura_project_id

# Optional additional paid RPCs. Ponder falls through to these on 429 /
# timeout from the primary. Leave empty if you only have one RPC key;
# a single paid provider capped at maxRequestsPerSecond in ponder.config.ts
# is usually enough to backfill and keep up with tip.
PONDER_RPC_URL_2=
PONDER_RPC_URL_3=

# --- Postgres (REQUIRED) -----------------------------------------------------
# Three passwords: postgres superuser plus the two least-privilege roles
# created by db/init.sh. Pick anything, but rotate before production.
POSTGRES_PASSWORD=change_me_super
PONDER_DB_PASSWORD=change_me_ponder
WEB_DB_PASSWORD=change_me_web

# --- Web service (optional, sensible defaults) -------------------------------
# Host port mapped to the web container's 3000.
WEB_PORT=3000
# Fully-qualified origin for SvelteKit's adapter-node. Must match how users
# reach the site (browsers, not the internal docker network).
WEB_ORIGIN=http://localhost:3000
# Goals Tracker target (active loan count). Read by the web container only.
PUBLIC_GOAL_TARGET=100

# --- ENS resolution (optional) -----------------------------------------------
# Mainnet RPC used by the web container for reverse-ENS lookups. Defaults
# to a free public node if unset. This URL is read-only public data and is
# intentionally separate from PONDER_RPC_URL_1.
ENS_RPC_URL=
