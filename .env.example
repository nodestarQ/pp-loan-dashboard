# Ethereum mainnet RPC for the Ponder indexer (Infura, Alchemy, etc).
# Only the indexer container reads this. The web container never sees it.
PONDER_RPC_URL_1=https://mainnet.infura.io/v3/your_infura_project_id

# Postgres. Shared by Ponder (ponder_rw role) and the web app (web_ro role).
# The compose stack provisions both roles automatically.
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Target count of active loans for the Goals Tracker (UI label + env fallback).
PUBLIC_GOAL_TARGET=100
