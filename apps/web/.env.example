# =============================================================================
# Local dev env for the SvelteKit web app.
# Copy to apps/web/.env and fill in WEB_DB_PASSWORD from your root .env.
# =============================================================================
#
# Only needed when running the frontend locally via `pnpm dev:web`. When the
# web app runs inside docker compose it receives its config from the root
# .env via docker-compose.yml, not this file.
#
# Prerequisite: run `pnpm dev:stack` first so postgres and the indexer are
# up with their ports published on 127.0.0.1 (see docker-compose.dev.yml).

# --- Postgres (REQUIRED) -----------------------------------------------------
# Use the least-privilege web_ro role. The password must match WEB_DB_PASSWORD
# in the root .env that seeded the compose postgres volume.
DATABASE_URL=postgres://web_ro:change_me_web@localhost:5432/huddle

# --- Indexer (REQUIRED) ------------------------------------------------------
# Points at the Ponder HTTP server inside the indexer container, via the
# host port published by docker-compose.dev.yml. Used by /api/sync-status.
PONDER_URL=http://localhost:42069

# --- ENS resolution (optional) -----------------------------------------------
# Mainnet RPC for reverse-ENS lookups. Falls back to a free public node.
ENS_RPC_URL=

# --- Public config (optional) ------------------------------------------------
# Goals Tracker target (active loan count). Defaults to 100 if unset.
PUBLIC_GOAL_TARGET=100
