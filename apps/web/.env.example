# =============================================================================
# Local dev env for the SvelteKit web app.
# Copy to apps/web/.env and fill in WEB_DB_PASSWORD from your root .env.
# =============================================================================
#
# Only needed when running the frontend locally via `pnpm dev:web`. When the
# web app runs inside docker compose it receives its config from the root
# .env via docker-compose.yml, not this file.
#
# Prerequisite: run `pnpm dev:stack` first so postgres and the indexer are
# up with their ports published on 127.0.0.1 (see docker-compose.dev.yml).

# --- Postgres (REQUIRED) -----------------------------------------------------
# Use the least-privilege web_ro role. The password must match WEB_DB_PASSWORD
# in the root .env that seeded the compose postgres volume.
DATABASE_URL=postgres://web_ro:change_me_web@localhost:5432/huddle

# --- Indexer (REQUIRED) ------------------------------------------------------
# Points at the Ponder HTTP server inside the indexer container, via the
# host port published by docker-compose.dev.yml. Used by /api/sync-status.
PONDER_URL=http://localhost:42069

# --- OpenSea identity resolution (optional but recommended) ------------------
# OpenSea API v2 key for leaderboard username / pfp / Twitter lookups.
# Same key as OPENSEA_API_KEY in the root .env; safe to reuse. Without a
# key the dashboard still renders, just without profile data.
OPENSEA_API_KEY=

# --- Public config (optional) ------------------------------------------------
# Goals tracker target (active loan count). Defaults to 130 if unset.
PUBLIC_GOAL_TARGET=130

# --- SIWE auth (REQUIRED for holder/borrower data) ---------------------------
# Server-only HMAC key for session cookies. Generate a fresh value with:
#   openssl rand -hex 32
# Must be at least 32 chars. Changing it invalidates all existing sessions.
AUTH_SECRET=

# Comma-separated list of EVM addresses allowed to view the gated leaderboards.
# Comparison is case-insensitive. Leave empty to fully disable access until
# at least one address is added.
WALLET_WHITELIST=

# --- Soft launch (optional) --------------------------------------------------
# When set, the entire site is gated behind /unlock with this shared password
# and the SIWE wallet whitelist is bypassed (password-holders see leaderboards
# directly). Leave empty/unset for production mode where SIWE applies.
EARLY_ACCESS_PASSWORD=
